{
  "name": "docs",
  "private": true,
  "version": "6.14.0",
  "license": "MIT",
  "scripts": {
    "check": "pnpm biome check",
    "check:fix": "pnpm biome check --write",
    "dev": "NODE_OPTIONS='--openssl-legacy-provider' storybook dev -p 6006",
    "build:abilities": "node src/generate-abilities.mjs",
    "build:docs": "NODE_OPTIONS='--openssl-legacy-provider' storybook build -o dist",
    "build": "pnpm run --sequential \"/^build:.*/\"",
    "ts:check": "tsc --noEmit"
  },
  "engines": {
    "node": "22",
    "pnpm": "10"
  },
  "dependencies": {
    "prettier": "^3.8.3",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@hookform/resolvers": "^3.10.0",
    "@mdx-js/react": "^3.1.1",
    "@storybook/addon-docs": "^9.1.20",
    "@storybook/addon-links": "^9.1.20",
    "@storybook/addon-styling-webpack": "^2.0.0",
    "@storybook/cli": "^9.1.20",
    "@storybook/icons": "^1.6.0",
    "@storybook/react-vite": "^9.1.20",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.19.17",
    "@types/react": "19.2.13",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^5.2.0",
    "babel-loader": "^10.1.1",
    "date-fns": "^4.1.0",
    "js-yaml": "^4.1.1",
    "msw": "^2.13.3",
    "react-hook-form": "7.62.0",
    "react-select": "^5.10.2",
    "remark-gfm": "^4.0.1",
    "storybook": "^9.1.20",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.9.3",
    "vite": "^7.3.2",
    "vite-tsconfig-paths": "^5.1.4",
    "zod": "^3.25.76"
  },
  "msw": {
    "workerDirectory": "public"
  }
